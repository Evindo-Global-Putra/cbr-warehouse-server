{
  "name": "server",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun --watch --env-file=.env.local src/index.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "docker:rebuild": "docker-compose build --no-cache && docker-compose up -d",
    "docker:db:up": "docker-compose up postgres-dev -d",
    "docker:db:down": "docker-compose down postgres-dev",
    "docker:db:logs": "docker-compose logs -f postgres-dev",
    "docker:app:up": "docker-compose up app-dev -d",
    "docker:app:down": "docker-compose down app-dev",
    "docker:app:logs": "docker-compose logs -f app-dev",
    "docker:app:shell": "docker exec -it cbr-app-dev sh",
    "db:test": "bun --env-file=.env.local src/db/test-connection.ts",
    "db:push": "bun --env-file=.env.local drizzle-kit push",
    "db:generate": "bun --env-file=.env.local drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.local drizzle-kit migrate",
    "db:studio": "bun --env-file=.env.local drizzle-kit studio",
    "db:psql": "docker exec -it cbr-postgres-dev psql -U postgres -d cbr-server-dev",
    "db:seed": "bun --env-file=.env.local src/db/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8"
  },
  "module": "src/index.js"
}
